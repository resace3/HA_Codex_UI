{
  "name": "HA_Codex_UI CI Devcontainer",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "workspaceFolder": "/workspaces/HA_Codex_UI",
  "containerEnv": {
    "HA_CODEX_UI_DIRECT_ACCESS": "1",
    "PORT": "8107"
  },
  "remoteEnv": {
    "GITHUB_ACTIONS": "${localEnv:GITHUB_ACTIONS}"
  },
  "postCreateCommand": "bash .devcontainer/postCreateCommand.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "github.vscode-github-actions",
        "ms-azuretools.vscode-docker"
      ]
    }
  },
  "forwardPorts": [8107],
  "portsAttributes": {
    "8107": {
      "label": "HA_Codex_UI"
    }
  }
}
